DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Server-pinned provider. Value is "openai" or "gemini".
# Only the matching *_API_KEY below is required; the other may stay blank.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Comma-separated exact origins allowed to call the API. No wildcards.
CORS_ALLOWED_ORIGINS=http://localhost:5173
